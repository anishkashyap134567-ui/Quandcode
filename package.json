{
  "name": "quandcode",
  "version": "0.1.0",
  "private": true,
  "description": "QuandCode — AI Coding Agent",
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "bun run --filter '@quandcode/*' dev",
    "build": "bun run --filter '@quandcode/*' build",
    "typecheck": "tsc --noEmit",
    "quandcode": "bun run packages/core/src/cli/index.ts",
    "test": "bun run scripts/run-all-tests.ts"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "bun-types": "^1.3.14",
    "chalk": "^5.6.2",
    "typescript": "^5.7.0"
  }
}
